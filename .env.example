# Modelos usados pelos agentes (ver src/llm/config.py)
CHAT_MODEL="ollama:llama3.1:8b"
EXTRACTION_MODEL="ollama:granite4.1:3b"

# URL do servidor Ollama local
OLLAMA_API_URL=http://localhost:11434

# Caminho do SQLite (ou DSN do Postgres) usado pelo checkpointer
DB_DSN=data/database.db

# Chaves de API para modelos em nuvem (opcional)
OPENAI_API_KEY=sua_chave_aqui
ANTHROPIC_API_KEY=sua_chave_aqui
GOOGLE_API_KEY=sua_chave_aqui

# Observabilidade (opcional)
LANGSMITH_API_KEY=sua_chave_aqui
LANGSMITH_TRACING=true
